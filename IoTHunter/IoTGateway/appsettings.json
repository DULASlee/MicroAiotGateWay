{
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5080"
      }
    }
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "MessageTimeoutMs": 5000,
    "ClientId": "iot-gateway",
    "MaxInFlight": 5
  },
  "Mqtt": {
    "WebSocketUrl": "ws://localhost:8083/mqtt",
    "ClientId": "iot-gateway-mqtt",
    "AutoReconnectDelayMs": 5000
  },
  "OpenTelemetry": {
    "OtlpEndpoint": ""
  }
}
