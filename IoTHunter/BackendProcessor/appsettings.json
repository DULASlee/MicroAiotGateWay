{
  "AllowedHosts": "*",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5081"
      }
    }
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:4317"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "Consumers": {
      "Persistence": {
        "GroupId": "iot-persistence",
        "Topics": [ "telemetry.raw", "event.critical" ]
      },
      "LatestProjection": {
        "GroupId": "iot-latest-projection",
        "Topics": [ "telemetry.raw", "event.critical" ]
      },
      "TimeseriesProjection": {
        "GroupId": "iot-timeseries-projection",
        "Topics": [ "telemetry.raw", "event.critical" ]
      }
    }
  },
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=iothunter;Username=iothunter;Password=iothunter123",
    "Redis": "localhost:6379"
  },
  "TimeseriesProjection": {
    "Enabled": false
  }
}
